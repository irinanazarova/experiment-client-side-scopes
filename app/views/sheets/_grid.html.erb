<%# The live area, composed of three reactive regions (see LiveRegion). Each
    is bound to the SQL it depends on and re-renders independently when that
    result set changes: edit a visible cell and all three resettle; edit a
    cell outside the window and the aggregates resettle while the grid body
    stays put. One ERB partial per region renders the host first paint, the
    slice first paint, and every slice re-render. %>
<%= live_region :stats, sheet: sheet, tag: :section,
      id: "sheet-stats", class: "grid grid-cols-2 md:grid-cols-4 gap-3 mb-4" %>

<div class="ss-wrap">
  <table class="ss" id="grid">
    <thead id="grid-head">
      <tr>
        <th class="ss-corner">#</th>
        <th class="ss-rowmax">Max</th>
        <% (1..sheet.col_count).each do |col| %>
          <th>C<%= col %></th>
        <% end %>
      </tr>
    </thead>
    <%= live_region :totals, sheet: sheet, tag: :tbody, id: "grid-totals" %>
    <%= live_region :rows, sheet: sheet, tag: :tbody, id: "grid-body" %>
  </table>
</div>
<p class="text-xs text-gray-400 mt-2" id="grid-note">
  Showing rows 1–<%= row_limit %> of <%= number_with_delimiter(sheet.row_count) %>.
  The stats, the Max column and the Σ row each aggregate locally and update
  independently.
</p>
