<%# The coarse reactive receiver: ONE Turbo Frame holding the whole grid. When
    the local change signal fires, the page reloads this frame (Turbo extracts
    the matching id from a fresh render of the page) and morphs it in. No live
    regions, no per-fragment SQL: a single frame, a single trigger. The same
    partials the precise route uses render inside it, so the markup is identical.

    refresh="morph" makes the reload morph the frame in place rather than
    replacing it, so scroll position and the flash diff survive the update. %>
<turbo-frame id="sheet-grid" refresh="morph"
             data-signal-sql="<%= signal.sql %>"
             data-reload-url="<%= coarse_sheet_path(sheet) %>">
  <section id="sheet-stats" class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
    <%= render "sheets/stats", stats: stats %>
  </section>

  <div class="ss-wrap">
    <table class="ss" id="grid">
      <thead id="grid-head">
        <tr>
          <th class="ss-corner">#</th>
          <th class="ss-rowmax">Max</th>
          <% (1..sheet.col_count).each do |col| %>
            <th>C<%= col %></th>
          <% end %>
        </tr>
      </thead>
      <tbody id="grid-totals">
        <%= render "sheets/totals", sheet: sheet, sums: sums, stats: stats %>
      </tbody>
      <tbody id="grid-body">
        <%= render "sheets/rows", sheet: sheet, row_limit: row_limit, values: values %>
      </tbody>
    </table>
  </div>
  <p class="text-xs text-gray-400 mt-2" id="grid-note">
    Showing rows 1–<%= row_limit %> of <%= number_with_delimiter(sheet.row_count) %>.
    The whole grid is one frame; any cell change reloads it.
  </p>
</turbo-frame>
